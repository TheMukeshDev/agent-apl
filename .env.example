# SportSphere AI Environment Variables Example
# Duplicate this file as '.env' and fill in your actual values.

# --- Backend Configuration ---
# Gemini API Key (Required for AI Natural Language Parsing)
GEMINI_API_KEY=

# Google Maps API Key (For Map Integration in production)
GOOGLE_MAPS_API_KEY=

# Server Port (optional, default is 8000)
PORT=8000

# Backend URL (used for CORS or callback references)
BACKEND_URL=http://localhost:8000

# Optional Database Configurations (Future Integration)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sportsphere-ai.web.app

# --- Frontend Configuration ---
# API base URL for the Vite frontend client
VITE_API_URL=http://localhost:8000
